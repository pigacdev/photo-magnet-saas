# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/photo_magnet?schema=public"

# Server
API_PORT=4000
CORS_ORIGIN=http://localhost:3000
NODE_ENV=development
# Clerk (seller auth) — put real values in .env.local (never commit secrets to .env.example)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=
# Svix signing secret from Clerk Dashboard → Webhooks (preferred name)
CLERK_WEBHOOK_SIGNING_SECRET=
# Legacy alias still read by the app if SIGNING_SECRET is unset
CLERK_WEBHOOK_SECRET=
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard
# Enable automatic media cleanup jobs (set to true in production only)
ENABLE_MEDIA_CLEANUP_CRON=false
# If set, POST /api/admin/media-cleanup/abandoned-sessions/global also requires header X-Media-Cleanup-Secret
# MEDIA_CLEANUP_SECRET=

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:4000
# Public URL of the Next app (Stripe subscription billing redirects)
APP_URL=http://localhost:3000

# S3-compatible storage
S3_BUCKET=
S3_REGION=us-east-1
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# Stripe — legacy seller subs only (optional); buyer order payments are separate
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Unused for customer checkout
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Email (Resend — new-order notifications to sellers)
RESEND_API_KEY=
# Optional platform sender when seller notification email is not used (dev default: onboarding@resend.dev)
RESEND_FROM_EMAIL=
