generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ---------------------------------------------------------------------------
// Enums
// ---------------------------------------------------------------------------

enum Role {
  ADMIN
  STAFF
}

enum ContextType {
  EVENT
  STOREFRONT
}

enum PricingType {
  PER_ITEM
  BUNDLE
}

enum PaymentStatus {
  PENDING
  PAID
  CASH
  FAILED
}

enum OrderSessionStatus {
  ACTIVE
  ABANDONED
  CONVERTED
}

enum SessionImageStatus {
  UPLOADED
  FAILED
}

enum ShapeType {
  SQUARE
  CIRCLE
  RECTANGLE
}

// ---------------------------------------------------------------------------
// 1. Core tables
// ---------------------------------------------------------------------------

model User {
  id               String    @id @default(uuid())
  email            String    @unique
  name             String?
  passwordHash     String
  role             Role      @default(ADMIN)
  stripeCustomerId String?   @unique
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  events       Event[]
  storefronts  Storefront[]
  printBatches PrintBatch[]
}

model Event {
  id        String    @id @default(uuid())
  userId    String
  name      String
  startDate DateTime
  endDate   DateTime
  isActive  Boolean   @default(true)
  /// Business cap on magnets per order; null = no business limit (system cap still applies).
  maxMagnetsPerOrder Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Storefront {
  id        String    @id @default(uuid())
  userId    String
  name      String
  isActive  Boolean   @default(true)
  /// Business cap on magnets per order; null = no business limit (system cap still applies).
  maxMagnetsPerOrder Int?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ---------------------------------------------------------------------------
// 2. Pricing (polymorphic: belongs to Event OR Storefront)
// ---------------------------------------------------------------------------

model Pricing {
  id          String      @id @default(uuid())
  contextType ContextType
  contextId   String
  type        PricingType
  price       Decimal     @db.Decimal(10, 2)
  currency     String      @default("EUR")
  quantity     Int?
  displayOrder Int?
  createdAt    DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
  deletedAt   DateTime?

  @@index([contextType, contextId])
}

// ---------------------------------------------------------------------------
// 2b. Customer order sessions (QR flow — not persisted orders)
// ---------------------------------------------------------------------------

model OrderSession {
  id           String             @id @default(uuid())
  contextType  ContextType
  contextId    String
  status       OrderSessionStatus @default(ACTIVE)
  createdAt    DateTime           @default(now())
  /// Session start (set on create; same instant as first activity for new sessions).
  startedAt    DateTime           @default(now())
  /// Bumped on each successful GET /api/session (presence / debugging / future analytics).
  lastActiveAt DateTime           @default(now())
  expiresAt    DateTime

  selectedShapeId String?
  /// Mirrors seller pricing mode for this selection (PER_ITEM = per magnet, BUNDLE = tier).
  pricingType     PricingType?
  quantity        Int?
  /// Pricing row id when pricingType is BUNDLE.
  bundleId        String?
  totalPrice      Decimal?        @db.Decimal(10, 2)

  sessionImages SessionImage[]

  @@index([contextType, contextId])
  @@index([expiresAt])
  @@index([lastActiveAt])
}

model SessionImage {
  id          String             @id @default(uuid())
  sessionId   String
  originalUrl String
  width       Int
  height      Int
  fileSize    Int
  status      SessionImageStatus @default(UPLOADED)
  createdAt   DateTime           @default(now())
  /// Order within the session (crop / print). Assigned on upload: lastPosition + 1 per file.
  position    Int
  /// True when width or height is below shape-aware minimum (see getMinRequiredPx); non-blocking. Crop may refine later.
  isLowResolution Boolean @default(false)

  session OrderSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, position])
}

// ---------------------------------------------------------------------------
// 3. Orders (polymorphic: belongs to Event OR Storefront)
// ---------------------------------------------------------------------------

model Order {
  id            String        @id @default(uuid())
  orderNumber   String        @unique
  customerName  String
  paymentStatus PaymentStatus @default(PENDING)
  totalPrice    Decimal       @db.Decimal(10, 2)
  contextType   ContextType
  contextId     String
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  deletedAt     DateTime?

  images Image[]

  @@index([contextType, contextId])
  @@index([paymentStatus])
}

// ---------------------------------------------------------------------------
// 4. Images (CRITICAL TABLE — carries print-production data)
// ---------------------------------------------------------------------------

model Image {
  id      String @id @default(uuid())
  orderId String

  // File data
  originalImageUrl    String
  originalImageWidth  Int
  originalImageHeight Int

  // Crop data (CRITICAL — normalized values)
  cropX     Float
  cropY     Float
  zoomLevel Float
  rotation  Float @default(0)

  // Output config
  shapeType     ShapeType
  outputWidthPx Int
  outputHeightPx Int

  // Status
  printedFlag Boolean @default(false)

  // Metadata
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  order           Order            @relation(fields: [orderId], references: [id], onDelete: Cascade)
  printBatchItems PrintBatchItem[]

  @@index([orderId])
  @@index([printedFlag])
}

// ---------------------------------------------------------------------------
// 5. Print system
// ---------------------------------------------------------------------------

model PrintBatch {
  id        String   @id @default(uuid())
  userId    String
  pdfUrl    String
  createdAt DateTime @default(now())

  user  User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items PrintBatchItem[]

  @@index([userId])
}

model PrintBatchItem {
  id           String @id @default(uuid())
  printBatchId String
  imageId      String

  printBatch PrintBatch @relation(fields: [printBatchId], references: [id], onDelete: Cascade)
  image      Image      @relation(fields: [imageId], references: [id], onDelete: Cascade)

  @@index([printBatchId])
  @@index([imageId])
}

// ---------------------------------------------------------------------------
// 6. Allowed shapes (polymorphic: belongs to Event OR Storefront)
// ---------------------------------------------------------------------------

model AllowedShape {
  id          String      @id @default(uuid())
  contextType ContextType
  contextId   String
  shapeType    ShapeType
  widthMm      Float
  heightMm     Float
  displayOrder Int       @default(0)

  @@unique([contextType, contextId, shapeType, widthMm, heightMm])
  @@index([contextType, contextId])
}
