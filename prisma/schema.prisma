generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

/// Seller org (1:1 with User). Billing + SaaS limits; `id` matches `User.id`.
model Organization {
  id                   String   @id
  plan                 Plan     @default(FREE)
  ordersThisMonth      Int      @default(0)
  /// FREE tier cap; PRO ignores (see `saas.ts`).
  orderLimit           Int      @default(10)
  eventsCreatedThisMonth Int    @default(0)
  /// Max events created per billing period; PRO uses high sentinel (see `saas.ts`).
  eventLimit           Int      @default(1)
  currentPeriodStart   DateTime @default(now())
  currentPeriodEnd     DateTime
  /// Clerk subscription payment period (renewal); not used for order/event quotas.
  subscriptionPeriodStart DateTime?
  subscriptionPeriodEnd   DateTime?
  stripeCustomerId     String?  @unique
  stripeSubscriptionId String?
  /// Clerk Billing subscription id (`subscription.*` webhooks).
  clerkSubscriptionId  String?
  /// Last synced Clerk User Plan slug (e.g. free_user, hobby, pro).
  clerkPlanSlug        String?
  /// ISO 4217 magnet order currency; null until seller onboarding completes.
  currency             String?
  /// Set when currency is first saved in onboarding or account settings.
  initialSetupAt       DateTime?
  /// UI date display preset: DMY | MDY | YMD (display only).
  dateFormat           String?
  /// UI magnet size unit: mm | cm | in (display only; storage stays mm).
  sizeUnit             String?
  /// Seller business/shop display name; used in customer email branding.
  name                 String?
  /// AES-256-GCM encrypted Resend API key (Pro own-domain sending).
  resendApiKeyEncrypted String?  @map("resend_api_key_encrypted")
  /// Verified sender email on seller's Resend domain (Pro).
  resendFromEmail      String?  @map("resend_from_email")
  /// Optional display name for resendFromEmail (Pro).
  resendFromName       String?  @map("resend_from_name")
  /// Set when Pro Resend settings are first saved.
  resendConfiguredAt   DateTime? @map("resend_configured_at")
  /// Active early-access promo window (60-day launch pricing).
  isEarlyAccess              Boolean   @default(false)
  earlyAccessExpiresAt       DateTime?
  /// Platform owner toggle: transition to hobby_loyalty / pro_loyalty at expiry.
  grantLifetimeDiscount      Boolean   @default(false)
  /// Prevent duplicate 7-day heads-up emails.
  earlyAccessHeadsUpSentAt   DateTime?
  orders               Order[]
  customers            Customer[]
  user                 User     @relation(fields: [id], references: [id], onDelete: Cascade)
}

/// Seller CRM customer; linked from orders at commit. Soft-deleted rows hidden from list.
model Customer {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  email          String?
  phone          String?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  orders       Order[]

  @@index([organizationId])
  @@index([organizationId, deletedAt])
  @@index([organizationId, email])
  @@index([organizationId, phone])
}

/// Stripe webhook idempotency: one row per processed `evt_...` id.
model ProcessedStripeEvent {
  /// Stripe event id
  id        String   @id
  createdAt DateTime @default(now())
}

/// Clerk webhook idempotency: one row per Svix `svix-id` header.
model ProcessedClerkEvent {
  id        String   @id
  createdAt DateTime @default(now())
}

/// Singleton row (id=1) tracking early-access seat consumption.
model EarlyAccessCounter {
  id            Int       @id @default(1)
  seatsTaken    Int       @default(0)
  /// Set when early plans are hidden and regular hobby/pro are made public.
  plansFlippedAt DateTime?
}

model User {
  id           String        @id @default(uuid())
  clerkId      String?       @unique
  email        String        @unique
  name         String?
  passwordHash String?
  role         Role          @default(ADMIN)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  deletedAt    DateTime?
  /// When seller accepted Terms/Privacy (mirrored from Clerk or re-consent modal).
  legalAcceptedAt DateTime?
  /// Policy version accepted (see legalConstants).
  legalVersion    String?
  /// Hard purge scheduled after soft-delete (account erasure grace period).
  erasureScheduledAt DateTime?
  /// Opt out of marketing-adjacent emails (early access notices).
  marketingEmailsOptOut Boolean @default(false)
  events       Event[]
  organization Organization?
  storefronts  Storefront[]
}

model Event {
  id                 String    @id @default(uuid())
  userId             String
  name               String    @db.VarChar(100)
  startDate          DateTime
  endDate            DateTime
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  /// Business cap on magnets per order; null = no business limit (system cap still applies).
  maxMagnetsPerOrder Int?
  /// Shown on seller print PDFs (magnets); max 40 chars.
  brandText          String?   @db.VarChar(40)
  /// Public entry page banner; null = no banner.
  bannerUrl          String?
  /// Seller receives new-order emails when `sendOrderEmails` is true.
  notificationEmail  String?
  sendOrderEmails    Boolean   @default(false)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Storefront {
  id                 String    @id @default(uuid())
  userId             String
  name               String
  isActive           Boolean   @default(true)
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?
  /// Business cap on magnets per order; null = no business limit (system cap still applies).
  maxMagnetsPerOrder Int?
  /// Shown on seller print PDFs (magnets); max 40 chars.
  brandText          String?   @db.VarChar(40)
  /// Seller receives new-order emails when `sendOrderEmails` is true.
  notificationEmail  String?
  sendOrderEmails    Boolean   @default(false)
  /// Seller pickup location; same shape as delivery shippingAddress.
  pickupAddress      Json?
  /// Inclusive vacation start (UTC date); null when no vacation scheduled.
  vacationFrom       DateTime?
  /// Inclusive vacation end (UTC date); null when no vacation scheduled.
  vacationTo         DateTime?
  /// Optional message shown on the public storefront during vacation.
  vacationNote       String?   @db.VarChar(500)
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Pricing {
  id           String      @id @default(uuid())
  contextType  ContextType
  contextId    String
  type         PricingType
  price        Decimal     @db.Decimal(10, 2)
  currency     String      @default("EUR")
  quantity     Int?
  displayOrder Int?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  deletedAt    DateTime?

  @@index([contextType, contextId])
}

model OrderSession {
  id              String                @id @default(uuid())
  contextType     ContextType
  contextId       String
  status          OrderSessionStatus    @default(ACTIVE)
  /// Customer checkout flow (session lifecycle; not the same as Order.status).
  checkoutStage   SessionCheckoutStage  @default(BUILDING)
  createdAt       DateTime              @default(now())
  expiresAt       DateTime
  /// Bumped on each successful GET /api/session (presence / debugging / future analytics).
  lastActiveAt    DateTime           @default(now())
  /// Session start (set on create; same instant as first activity for new sessions).
  startedAt       DateTime           @default(now())
  /// PER_ITEM: snapshot of [{ imageId, copies }] at Stripe redirect; required for webhook order creation.
  checkoutImageCopies     Json?
  /// Pricing row id when pricingType is BUNDLE.
  bundleId        String?
  /// Mirrors seller pricing mode for this selection (PER_ITEM = per magnet, BUNDLE = tier).
  pricingType     PricingType?
  quantity        Int?
  selectedShapeId String?
  totalPrice      Decimal?           @db.Decimal(10, 2)
  /// Set when session is committed to an Order (idempotency + link).
  orderId         String?            @unique
  order           Order?             @relation(fields: [orderId], references: [id])
  /// Stripe Checkout Session id before order exists (session-first payment flow).
  stripeCheckoutSessionId String?
  /// From Checkout `payment_intent` (id); useful for support before Order exists.
  stripePaymentIntentId   String?
  /// From Checkout `payment_status` (e.g. unpaid, paid). Not PaymentIntent.status. Not in GET /api/session.
  stripePaymentStatus     String?
  /// Customer snapshot for session-first online payment (webhook / post-success order creation). Not in GET /api/session.
  checkoutCustomerName    String?
  checkoutCustomerEmail   String?
  checkoutCustomerPhone   String?
  checkoutShippingType    String?
  checkoutShippingAddress Json?
  sessionImages   SessionImage[]

  @@index([contextType, contextId])
  @@index([expiresAt])
  @@index([lastActiveAt])
  @@index([checkoutStage])
}

model SessionImage {
  id              String             @id @default(uuid())
  sessionId       String
  originalUrl     String
  width           Int
  height          Int
  fileSize        Int
  status          SessionImageStatus @default(UPLOADED)
  createdAt       DateTime           @default(now())
  /// Set when abandoned-session media cleanup removed the blob (filesystem/S3); row is retained.
  mediaDeletedAt  DateTime?
  /// Order within the session (crop / print). Assigned on upload: lastPosition + 1 per file.
  /// List queries: always ORDER BY position ASC, createdAt ASC (see server magnetImageOrderBy.ts).
  position        Int
  /// True when width or height is below shape-aware minimum (see getMinRequiredPx); non-blocking. Crop may refine later.
  isLowResolution Boolean            @default(false)
  cropHeight      Int?
  /// Placeholder for future rotation (degrees); print pipeline not implemented yet.
  cropRotation    Float              @default(0)
  /// Zoom factor relative to minimum cover scale (>= 1). Optional UI restore / debug.
  cropScale       Float?
  /// Pan in frame CSS px (relative to frame center). Optional UI restore.
  cropTranslateX  Float?
  cropTranslateY  Float?
  cropWidth       Int?
  /// Crop rectangle in original image pixels (fixed-frame editor); set when user saves/adjusts.
  cropX           Int?
  cropY           Int?
  session         OrderSession       @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([sessionId, position])
  @@index([sessionId, mediaDeletedAt])
}

model Order {
  id                      String            @id @default(uuid())
  organizationId          String
  contextType             ContextType
  contextId               String
  status                  OrderStatus       @default(NEW)
  totalPrice              Decimal           @db.Decimal(10, 2)
  currency                String            @default("EUR")
  /// Future: `pickedUpAt DateTime?` when customer collects at event. Not in DB yet.
  /// Completion rule (when added): physically done ⇔ `shippedAt != null OR pickedUpAt != null`.
  createdAt               DateTime          @default(now())
  /// Snapshot from OrderSession at commit (immutable); never re-derived from live Pricing rows.
  pricingType             PricingType
  quantity                Int?
  bundleId                String?
  /// Set when Stripe Checkout completes (webhook); optional until paid.
  stripeCheckoutSessionId String?
  /// Primary payment reference from Stripe (PaymentIntent id).
  stripePaymentIntentId   String?
  /// When available (card charge id from expanded PI).
  stripeChargeId          String?
  customerEmail           String?
  /// Set after buyer confirmation email is sent (idempotency guard).
  buyerConfirmationEmailSentAt DateTime?
  customerName            String?
  customerPhone           String?
  /// CRM link at order commit; optional after customer soft-delete.
  customerId              String?
  /// Seller marks production done. Reprints do not change this.
  printedAt               DateTime?
  /// Order left for shipping / mail. Event pickup may use a different field later.
  shippedAt               DateTime?
  shippingAddress         Json?
  shippingType            String?
  /// Event-only customer note: cash or card on location (informational; not a payment gate).
  eventPaymentPreference  String?
  /// Optional seller note when order is cancelled.
  cancellationNote        String?
  /// Buyer acknowledged Privacy/Terms at checkout.
  consentAcceptedAt       DateTime?
  consentVersion          String?
  /// When buyer PII on this order was anonymized (GDPR erasure).
  buyerPiiErasedAt        DateTime?
  /// Future: 6-char A–Z0–9 display id for UI and print (generated when implemented).
  shortCode               String?           @unique
  organization            Organization      @relation(fields: [organizationId], references: [id])
  customer                Customer?         @relation(fields: [customerId], references: [id], onDelete: SetNull)
  orderImages             OrderImage[]
  committedFromSession    OrderSession?

  @@index([organizationId])
  @@index([contextType, contextId])
  @@index([status])
  @@index([customerId])
}

/// Immutable print snapshot copied from SessionImage at commit time.
model OrderImage {
  id           String       @id @default(uuid())
  orderId      String
  originalUrl  String
  croppedUrl   String?
  cropX        Int
  cropY        Int
  cropWidth    Int
  cropHeight   Int
  rotation     Float        @default(0)
  width        Int
  height       Int
  /// Magnet sequence for print / exports; list queries: ORDER BY position ASC, createdAt ASC.
  position     Int
  /// Per-magnet (PER_ITEM) pricing: how many physical magnets from this crop (print PDF repeats this many times).
  copies       Int          @default(1)
  createdAt    DateTime     @default(now())
  /// Final Sharp extract output for print (local `/uploads/...` path when rendered).
  renderedUrl  String?
  /// AllowedShape at commit time; print sheets are generated per shape (never mixed on one PDF).
  shapeId      String
  /// Seller marked this line item produced (Phase 8; reprints do not clear).
  printed      Boolean      @default(false)
  printedAt    DateTime?
  /// Order-media blobs removed by retention cleanup (`uploads/order-images*`, matching S3 keys); row retained.
  mediaDeletedAt DateTime?
  /// Seller-initiated GDPR deletion; blob removed, row kept as tombstone.
  deletedAt      DateTime?
  deletedReason  String?
  order        Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  allowedShape AllowedShape @relation(fields: [shapeId], references: [id])

  @@index([orderId])
  @@index([orderId, position])
  @@index([orderId, mediaDeletedAt])
  @@index([shapeId])
}

model AllowedShape {
  id           String       @id @default(uuid())
  contextType  ContextType
  contextId    String
  shapeType    ShapeType
  widthMm      Float
  heightMm     Float
  displayOrder Int          @default(0)
  orderImages  OrderImage[]

  @@unique([contextType, contextId, shapeType, widthMm, heightMm])
  @@index([contextType, contextId])
}

enum Role {
  ADMIN
  STAFF
}

enum ContextType {
  EVENT
  STOREFRONT
}

enum PricingType {
  PER_ITEM
  BUNDLE
}

enum OrderSessionStatus {
  ACTIVE
  ABANDONED
  CONVERTED
  /// Auto-abandoned when session exceeded TTL (see checkout cleanup).
  EXPIRED
}

/// Session-scoped checkout lifecycle (independent of Order row).
enum SessionCheckoutStage {
  BUILDING
  CUSTOMER_DETAILS
  COMPLETED
  ABANDONED
}

enum SessionImageStatus {
  UPLOADED
  FAILED
}

/// Seller-managed order workflow (manual payment outside platform).
enum OrderStatus {
  NEW
  CONFIRMED
  INVOICE_SENT
  PAID
  IN_PRODUCTION
  SHIPPED
  COMPLETED
  CANCELLED
}

enum ShapeType {
  SQUARE
  CIRCLE
  RECTANGLE
}

enum Plan {
  FREE
  HOBBY
  PRO
}

/// Platform owner bulk email send audit (subject + counts only; no body stored).
model PlatformNotificationLog {
  id                 String   @id @default(cuid())
  sentByEmail        String
  subject            String
  recipientCount     Int
  skippedOptOutCount Int
  includeOptedOut    Boolean
  selectionMode      String
  filterSnapshot     Json?
  createdAt          DateTime @default(now())

  @@index([createdAt])
  @@index([sentByEmail])
}

/// Audit trail for GDPR erasure and DSAR actions.
model PrivacyAuditLog {
  id             String   @id @default(uuid())
  action         String
  actorEmail     String?
  organizationId String?
  targetType     String?
  targetId       String?
  metadata       Json?
  createdAt      DateTime @default(now())

  @@index([action])
  @@index([targetId])
  @@index([createdAt])
  @@index([organizationId])
}
